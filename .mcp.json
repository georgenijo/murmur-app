{
  "mcpServers": {
    "omen": {
      "type": "stdio",
      "command": "omen",
      "args": ["mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless",
        "--viewport-size=1280x720"
      ]
    },
    "murmur-diag": {
      "type": "stdio",
      "command": "bash",
      "args": ["tools/murmur-diag/run.sh"]
    }
  }
}
